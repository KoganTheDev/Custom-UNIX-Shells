<mxfile host="app.diagrams.net" agent="Claude" version="24.0.0">
  <diagram name="Standard Shell - Activity Diagram" id="standard-shell-activity">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
