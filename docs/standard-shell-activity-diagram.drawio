        <!-- Title -->
        <mxCell id="title" value="Standard Shell - Command Dispatch Loop (UML Activity Diagram)" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="-40" width="740" height="30" as="geometry" />
